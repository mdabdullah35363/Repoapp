# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Google Firebase Backend Configuration
# Users can securely manage these in the Secrets panel of the AI Studio UI.
# If left empty, the app runs on a robust, cached, offline-first local Room DB.
# If configured, the app pairs with your Firebase cloud back-end seamlessly.
FIREBASE_API_KEY=EMPTY
FIREBASE_PROJECT_ID=EMPTY
FIREBASE_DATABASE_URL=EMPTY
FIREBASE_APP_ID=EMPTY
